    {
      "name": "02_Auth",
      "item": [
        {
          "name": "GET KPI - Thiếu Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get(\"env\") === \"local\") {\r",
                  "    pm.test(\"Local backend strictly returns 401 for missing token\", function () {\r",
                  "        pm.expect(pm.response.code).to.equal(401);\r",
                  "    });\r",
                  "} else {\r",
                  "    pm.test(\"Mock server bypasses auth check with 200\", function () {\r",
                  "        pm.expect([200, 401]).to.include(pm.response.code);\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
